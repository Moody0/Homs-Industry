# Browser-safe Supabase project URL. This value is allowed in client bundles.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Browser-safe Supabase publishable key. Never put service-role keys in NEXT_PUBLIC variables.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional, server-only. Use only for privileged admin operations such as disabling/deleting Auth users.
# Never expose this key in client components, browser bundles, or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Useful for Supabase Auth redirect URLs in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. Current map embeds work without a key by using lat/lng iframe URLs.
# Add a key only if advanced Google Maps Platform features are implemented later.
GOOGLE_MAPS_API_KEY=
